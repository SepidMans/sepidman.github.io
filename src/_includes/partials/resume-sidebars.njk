<section class="resume-grid">
  <article class="resume-panel">
    <p class="eyebrow">Education</p>
    {% for item in resume.education %}
      <div class="resume-list-item">
        <h3>{{ item.institution }}</h3>
        <p>{{ item.studyType }}{% if item.area %} · {{ item.area }}{% endif %}</p>
        <p class="muted">{{ item.startDate | yearRange(item.endDate) }}</p>
        {% if item.summary %}
          <p>{{ item.summary }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </article>

  <article class="resume-panel">
    <p class="eyebrow">Skills</p>
    {% for item in resume.skills %}
      <div class="resume-list-item">
        <h3>{{ item.name }}</h3>
        <ul class="tag-list">
          {% for keyword in item.keywords %}
            <li>{{ keyword }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endfor %}
  </article>

  <article class="resume-panel">
    <p class="eyebrow">Training and languages</p>
    <div class="resume-list-item">
      <h3>Certifications</h3>
      <ul class="plain-list">
        {% for item in resume.certifications %}
          <li>{{ item.name }}{% if item.issuer %} · {{ item.issuer }}{% endif %}</li>
        {% endfor %}
      </ul>
    </div>
    <div class="resume-list-item">
      <h3>Languages</h3>
      <ul class="plain-list">
        {% for item in resume.languages %}
          <li>{{ item.language }} · {{ item.fluency }}</li>
        {% endfor %}
      </ul>
    </div>
    <div class="resume-list-item">
      <h3>Selected projects</h3>
      <ul class="plain-list">
        {% for item in resume.projects %}
          <li>{{ item.name }}</li>
        {% endfor %}
      </ul>
    </div>
  </article>
</section>
