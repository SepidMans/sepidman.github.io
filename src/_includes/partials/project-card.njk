<article class="project-card">
  <a class="project-card-link" href="{{ project.url }}">
    <div class="project-card-visual visual-swatch visual-swatch-{{ project.data.coverTone or 'sage' }}">
      <span>{{ project.data.role }}</span>
      <strong>{{ project.data.timeline }}</strong>
    </div>
    <div class="project-card-copy">
      <p class="eyebrow">{{ project.data.cardEyebrow or "Selected work" }}</p>
      <h3>{{ project.data.title }}</h3>
      <p>{{ project.data.summary }}</p>
      <ul class="tag-list">
        {% for tool in project.data.tools %}
          <li>{{ tool }}</li>
        {% endfor %}
      </ul>
    </div>
  </a>
</article>
